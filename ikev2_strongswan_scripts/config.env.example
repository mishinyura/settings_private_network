# Скопируй в config.env и поправь значения.
# cp config.env.example config.env

DOMAIN="vpn.yuramishin.ru"
VPN_USER="yura"

# Можно оставить пустым: run_all.sh или configure_strongswan.sh спросит пароль интерактивно.
# Пароль все равно будет записан в /etc/ipsec.secrets, так работает EAP-MSCHAPv2.
VPN_PASSWORD=""

VPN_POOL="10.10.10.0/24"
VPN_DNS="1.1.1.1,8.8.8.8"

# Скрипт возьмет интерфейс из ip route show default.
EXT_IF="auto"

# Если на сервере есть nginx, certbot standalone временно его остановит и потом запустит.
STOP_NGINX_FOR_CERTBOT="1"

# Если нужно перевыпустить сертификат даже при наличии старого.
FORCE_CERT_RENEWAL="1"
